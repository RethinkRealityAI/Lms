        {
          "orderIndex": 3,
          "blockType": "rich_text",
          "title": null,
          "data": {
            "html": "<p>Sarita is a 27 year old patient with Sickle Cell Disease who comes to your emergency department 4-5 times a year for pain relief related to her vaso-occlusive episode.</p>"

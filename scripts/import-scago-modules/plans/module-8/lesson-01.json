          "data": {
            "bullet_style": "disc",
            "items": [
              { "html": "Identify the most common health care setting HCP's can advocate for patients living with SCD." },
              { "html": "Consider the holistic needs of a patient living with SCD beyond their medical diagnosis, as well as the social barriers often encountered." },
              { "html": "Acknowledge the benefit of collaborating with other HCP's, community providers, patients and their families." },
              { "html": "Discuss how HCP's can grow in their roles and positively influence change in their support of patients living with SCD." }
            ],
            "gridX": 0, "gridY": 0, "gridW": 12, "gridH": 3
          }
        }
      ]
    },

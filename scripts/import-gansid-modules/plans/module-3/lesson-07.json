        {
          "orderIndex": 1,
          "blockType": "rich_text",
          "title": null,
          "data": {
            "html": "<h2>Informal Recognition</h2><p>Informal recognition is the way we conduct our relationship with volunteers <strong>every day</strong>. It does not involve formal processes — it is authentic and sincere.</p><p>Informal recognition exists and thrives within the organization only when a <strong>culture of recognition</strong> is cultivated. Informal recognition can come in the form of:</p>",
            "mode": "standard",
            "gridX": 0,
            "gridY": 1,
            "gridW": 12,
            "gridH": 3
          }
        },
        {

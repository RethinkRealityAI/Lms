          "data": {
            "question_type": "multiple_choice",
            "question": "Who is responsible for recognizing volunteers within an organization?",
            "options": [
              "Everyone in the organization",
              "Only the volunteer manager",
              "Only the organization's CEO",
              "Only the human resources department"
            ],
            "correct_answer": "Everyone in the organization",

            "gridH": 3
          }
        },
        {
          "orderIndex": 4,
          "blockType": "callout",
          "title": null,
          "data": {
            "mode": "callout",
            "variant": "info",
            "title": "Understanding Volunteer Preferences",
            "html": "<p>It's important to understand <strong>how volunteers want to be recognized</strong>. There are many ways to recognize volunteers, so be sure to survey your volunteers to get their thoughts and feedback on recognition activities. Tailor your approach to what resonates with each volunteer.</p>",
            "gridX": 0,
            "gridY": 4,
            "gridW": 12,
            "gridH": 3
          }

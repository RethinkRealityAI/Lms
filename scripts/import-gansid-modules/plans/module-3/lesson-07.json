        {
          "orderIndex": 1,
          "blockType": "rich_text",
          "title": null,
          "data": {
            "html": "<h2>What is Volunteer Recognition?</h2><p>Volunteer recognition is an important way to ensure volunteers feel valued for their contributions and proud to be part of the organization. It's a great way to demonstrate to volunteers the impact they are having or have had.</p>",
            "mode": "standard",
            "gridX": 0,
            "gridY": 1,
            "gridW": 12,
            "gridH": 3
          }
        },
        {
          "orderIndex": 2,
          "blockType": "callout",
          "title": null,
          "data": {
            "mode": "callout",
            "variant": "tip",
            "title": "Key Principle",
            "html": "<p>Recognition is not the sole responsibility of a volunteer manager — it involves <strong>everyone in the organization</strong> and should be <strong>proactive rather than reactive</strong>.</p>",
            "gridX": 0,
            "gridY": 2,
            "gridW": 12,
            "gridH": 3
          }
        },
        {
          "orderIndex": 3,
          "blockType": "rich_text",
          "title": null,
          "data": {
            "html": "<h2>Formal Recognition</h2><p>Formal recognition events and activities should align with both:</p><ul><li>The <strong>reasons a volunteer chooses to give their time</strong></li><li>The <strong>missions of the organization</strong></li></ul>",
            "mode": "standard",
            "gridX": 0,
            "gridY": 3,
            "gridW": 12,
            "gridH": 3
          }
        },
        {
          "orderIndex": 4,
          "blockType": "content_list",
          "title": null,
          "data": {
            "heading": "Formal recognition can take the form of:",
            "items": [
              { "html": "<p>Awards</p>" },
              { "html": "<p>Handwritten cards</p>" },
              { "html": "<p>Formal medal ceremonies (e.g., Distinguished Volunteer Award ceremonies)</p>" }
            ],
            "bullet_style": "disc",
            "enable_animations": false,
            "gridX": 0,
            "gridY": 4,
            "gridW": 12,
            "gridH": 3
          }
        },
        {
          "orderIndex": 5,
          "blockType": "content_list",
          "title": null,
          "data": {
            "heading": "If holding a formal event, prioritize logistics:",
            "items": [
              { "html": "<p>Where the event will be held</p>" },
              { "html": "<p>Who you are going to invite</p>" },
              { "html": "<p>What time of year you will hold the event</p>" },
              { "html": "<p>Why you want to host a formal event as opposed to an informal one</p>" }
            ],
            "bullet_style": "disc",
            "enable_animations": false,
            "gridX": 0,
            "gridY": 5,
            "gridW": 12,
            "gridH": 3
          }
        }
      ]
    },

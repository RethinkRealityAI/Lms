      "title": "The Logical Framework",
      "status": "published",
      "settings": { "background": "#FFFFFF", "block_style": "glass" },
      "blocks": [
        {
          "orderIndex": 0,
          "blockType": "rich_text",
          "title": null,
          "data": {
            "html": "<p>The logical framework is an excellent tool to help project managers in: Confirming activities of the project Seeing ways you could measure success Developing the skeleton of the project proposal</p><p>The logical framework will help you in deciding best course of action, understanding risks, and appreciating what you may assume will be done to have a successful project.</p>",
            "mode": "standard",
            "gridX": 0,
            "gridY": 0,
            "gridW": 12,
            "gridH": 3
          }
        },
        {
          "orderIndex": 1,
          "blockType": "table",
          "title": null,
          "data": {
            "columns": [
              { "key": "component", "label": "Component" },
              { "key": "definition", "label": "Definition" },
              { "key": "example", "label": "Example" }
            ],
            "rows": [
              { "cells": { "component": "Inputs", "definition": "Resources that your organization brings to the project.", "example": "Budget, Personnel, Materials" } },
              { "cells": { "component": "Activities", "definition": "Specific actions taken by your organization.", "example": "Conducting training workshops." } },
              { "cells": { "component": "Outputs", "definition": "Tangible products or services produced as a result of activities.", "example": "Number of new clients signed." } },
              { "cells": { "component": "Outcomes", "definition": "Short to medium-term changes or benefits for stakeholders.", "example": "Improved knowledge and skills among staff members as a result of a training session." } },
              { "cells": { "component": "Impact", "definition": "Long-term changes or broader effects on the community or system.", "example": "Increased employment rates due to improved skills." } }
            ],
            "first_column_header": true,
            "gridX": 0,
            "gridY": 1,
            "gridW": 12,
            "gridH": 3
          }
        }
      ]
    },

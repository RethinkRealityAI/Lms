          "title": null,
          "data": {
            "question_type": "true_false",
            "question": "Is the following statement true or false?\n\nStatement: The logical framework does not help see ways to measure success.",
            "options": ["True", "False"],
            "correct_answer": "False",
            "show_feedback": true,
            "feedback_correct": "False! One of the main benefits of a logical framework is that it helps you identify ways to measure success at each level — from outputs to impact.",

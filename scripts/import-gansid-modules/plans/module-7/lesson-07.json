        {
          "orderIndex": 1,
          "blockType": "rich_text",
          "title": null,
          "data": {
            "html": "<h3>Example SMARTIE Objective</h3><p><strong>Initial Objective:</strong> We will raise awareness about Sickle Cell Disease in Kenya.</p><p>Make it more specific.</p><p><strong>Revised Objective:</strong> We will conduct advocacy campaigns with policymakers on Sickle Cell Disease in Kenya.</p><p>Make it more measurable and timebound.</p><p><strong>Final Version of Objective:</strong> We will conduct an advocacy campaign for policymakers for a new Ministry of Health Sickle Cell Disease strategy for Kenya, completed by 2025.</p>",
            "mode": "standard",
            "gridX": 0,
            "gridY": 1,
            "gridW": 12,
            "gridH": 3
          }
        }
      ]

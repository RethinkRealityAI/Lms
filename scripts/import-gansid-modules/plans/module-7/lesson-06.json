          "blockType": "content_list",
          "title": null,
          "data": {
            "items": [
              { "html": "<p><strong>Expand the Background:</strong> Turn the background into a detailed problem statement with supporting data and evidence.</p>", "animation": "none" },
              { "html": "<p><strong>Expand the Rationale:</strong> Develop the rationale into a full implementation plan with activities, timelines, and responsibilities.</p>", "animation": "none" },
              { "html": "<p><strong>Formalize the Objectives:</strong> Ensure all objectives are SMART-IE (Specific, Measurable, Achievable, Realistic, Timebound, Inclusive, Equitable).</p>", "animation": "none" },
              { "html": "<p><strong>Add a Budget:</strong> Develop a detailed budget that covers all project costs.</p>", "animation": "none" },
              { "html": "<p><strong>Define Evaluation:</strong> Establish clear metrics and methods to measure success throughout the project.</p>", "animation": "none" }
            ],

          "blockType": "rich_text",
          "orderIndex": 0,
          "data": {
            "html": "<p><strong>The RACI Matrix</strong> (Responsible, Accountable, Consulted, Informed) is a key tool used in this phase to clarify roles and responsibilities for every task or decision in the project.</p>",
            "mode": "standard",
            "gridX": 0,
            "gridY": 0,
            "gridW": 12,
            "gridH": 3
          }
        },
        {
          "blockType": "table",

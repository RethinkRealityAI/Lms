    {
      "orderIndex": 9,
      "slideType": "content",
      "title": "That's it!",
      "status": "published",
      "settings": { "background": "#FFFFFF", "block_style": "glass" },
      "blocks": [
        {
          "orderIndex": 0,
          "blockType": "rich_text",
          "title": null,
          "data": {
            "html": "<p>Congratulations on completing the Understanding Effective Leadership lesson!</p><h3>Key Takeaways</h3>",
            "mode": "standard",
            "gridX": 0, "gridY": 0, "gridW": 12, "gridH": 3
          }
        },
        {
          "orderIndex": 1,
          "blockType": "content_list",
          "title": null,
          "data": {
            "items": [
              { "html": "<p><strong>Leadership matters:</strong> Effective leadership inspires motivation and drives organizational success.</p>", "animation": "none" },
              { "html": "<p><strong>Core qualities:</strong> Communication, empathy, and integrity are foundational to effective leadership.</p>", "animation": "none" },
              { "html": "<p><strong>Lead by example:</strong> Demonstrate the behaviors and values you expect from your team.</p>", "animation": "none" },
              { "html": "<p><strong>Adaptability:</strong> Embrace change and navigate challenges with flexibility.</p>", "animation": "none" },
              { "html": "<p><strong>Empower others:</strong> Delegate, trust, and create opportunities for growth.</p>", "animation": "none" },
              { "html": "<p><strong>Emotional intelligence:</strong> Understand and manage emotions to build strong relationships.</p>", "animation": "none" },
              { "html": "<p><strong>Continuous learning:</strong> Commit to ongoing growth and improvement.</p>", "animation": "none" }
            ],
            "bullet_style": "disc",
            "enable_animations": false,
            "gridX": 0, "gridY": 1, "gridW": 12, "gridH": 3
          }
        },
        {
          "orderIndex": 2,
          "blockType": "callout",
          "title": null,
          "data": {
            "mode": "callout",
            "variant": "info",
            "title": null,
            "html": "<p>Strong leadership is not a trait you are born with — it is a set of skills and habits that can be developed and refined throughout your career.</p>",
            "gridX": 0, "gridY": 2, "gridW": 12, "gridH": 3
          }
        }
      ]
    }
  ],

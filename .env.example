NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only — admin password reset / ban (see src/lib/supabase/service.ts)
SUPABASE_SERVICE_ROLE_KEY=

# Email — certificate + course-assignment notifications (see src/lib/email/mailer.ts)
# Per-tenant From headers override SMTP_FROM when set (format: Name <email@domain.com>)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_FROM_GANSID=
SMTP_FROM_SCAGO=
